# Copy this to secrets.yaml and fill in your values, then encrypt with:
#   sops --encrypt --in-place Nixos/secrets.yaml

cloudflare_apiToken: your-cloudflare-api-token
pihole_password: your-pihole-password
beszel_key: ssh-ed25519 your-beszel-public-key
beszel_token: your-beszel-agent-token
beszel_hubUrl: https://beszel.yourdomain.com
wireguard_privateKey: your-wireguard-private-key
wireguard_presharedKey: your-wireguard-preshared-key
wireguard_addresses: your-wireguard-addresses
wireguard_provider: your-vpn-provider
wireguard_type: wireguard
wireguard_region: your-vpn-region
suwayomi_user: your-suwayomi-username
suwayomi_password: your-suwayomi-password
nextcloud_redisPassword: your-nextcloud-redis-password

# Homepage APIs
homepage_jellyfin_key: your-jellyfin-api-key
homepage_jellyseerr_key: your-jellyseerr-api-key
homepage_suwayomi_username: your-suwayomi-username
homepage_suwayomi_password: your-suwayomi-password
homepage_qbittorrent_username: your-qbittorrent-username
homepage_qbittorrent_password: your-qbittorrent-password
homepage_prowlarr_key: your-prowlarr-api-key
homepage_sonarr_key: your-sonarr-api-key
homepage_radarr_key: your-radarr-api-key
homepage_pihole_key: your-pihole-api-key
homepage_gitea_key: your-gitea-api-token
homepage_beszel_username: your-beszel-username
homepage_beszel_password: your-beszel-password
